---
import PortfolioApp from "../components/PortfolioApp";
import BaseLayout from "../layouts/baseLayout.astro";
---

<BaseLayout>
  <PortfolioApp client:only="react" />

  <!-- About me section -->
  <section id="about" class="section-block">
    <div class="container">
      <div class="section-head">
        <h2 data-i18n="about">About Me</h2>
        <p data-i18n="aboutTag">
          Learning by building real projects and polishing the details.
        </p>
      </div>

      <div class="cards two-columns">
        <article class="card">
          <h3 data-i18n="aboutJourneyTitle">My journey</h3>
          <p data-i18n="aboutJourneyText">
            I'm a Computer Science student focused on growing as a web
            developer. I enjoy turning ideas into clean, interactive experiences
            and improving a little with every project.
          </p>
        </article>

        <article class="card">
          <h3 data-i18n="aboutGoalTitle">What I care about</h3>
          <p data-i18n="aboutGoalText">
            I like interfaces that feel alive, readable code, and projects that
            show both creativity and progress. This portfolio is part of that
            process.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Projects section -->
  <section id="projects" class="section-block projects-section">
    <div class="container">
      <div class="section-head">
        <h2 data-i18n="projects">Projects</h2>
        <p data-i18n="projectsTag">
          A few things I'm building and refining right now.
        </p>
      </div>

      <div class="cards project-grid">
        <article class="card project-card">
          <span class="pill">HTML / CSS / JS</span>
          <h3 data-i18n="projectOneTitle">This portfolio</h3>
          <p data-i18n="projectOneText">
            A personal site focused on animation, responsive layout, and a
            cleaner visual identity while I keep learning frontend fundamentals.
          </p>
        </article>

        <article class="card project-card">
          <span class="pill">UI Practice</span>
          <h3 data-i18n="projectTwoTitle">Landing page experiments</h3>
          <p data-i18n="projectTwoText">
            Small interface exercises where I test layout ideas, color
            combinations, hover states, and better content structure.
          </p>
        </article>

        <article class="card project-card">
          <span class="pill">Learning</span>
          <h3 data-i18n="projectThreeTitle">Frontend study workflow</h3>
          <p data-i18n="projectThreeText">
            A growing collection of mini builds that help me practice JavaScript
            interactions, accessibility basics, and responsive behavior.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Skills section -->
  <section id="skills" class="section-block">
    <div class="container">
      <div class="section-head">
        <h2 data-i18n="skills">Skills</h2>
        <p data-i18n="skillsTag">
          Tools and technologies I currently work with.
        </p>
      </div>

      <div class="cards two-columns">
        <article class="card skill-card">
          <h3 data-i18n="skillTechTitle">Technical skills</h3>
          <div class="skill-row">
            <span>Java</span>
            <div class="bar"><i style="width: 84%"></i></div>
          </div>
          <div class="skill-row">
            <span>HTML</span>
            <div class="bar"><i style="width: 88%"></i></div>
          </div>
          <div class="skill-row">
            <span>CSS</span>
            <div class="bar"><i style="width: 72%"></i></div>
          </div>
          <div class="skill-row">
            <span>JavaScript</span>
            <div class="bar"><i style="width: 68%"></i></div>
          </div>
          <div class="skill-row">
            <span>Git</span>
            <div class="bar"><i style="width: 70%"></i></div>
          </div>
        </article>

        <article class="card skill-card">
          <h3 data-i18n="skillSoftTitle">Strengths</h3>
          <div class="tag-list">
            <span class="tag-chip" data-i18n="skillOne">Problem solving</span>
            <span class="tag-chip" data-i18n="skillTwo"
              >Curiosity across tech</span
            >
            <span class="tag-chip" data-i18n="skillFive">Java foundation</span>
            <span class="tag-chip" data-i18n="skillSix"
              >Software and hardware interest</span
            >
            <span class="tag-chip" data-i18n="skillThree"
              >Continuous learning</span
            >
            <span class="tag-chip" data-i18n="skillFour">Git workflow</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Contact section -->
  <section id="contact" class="section-block">
    <div class="container">
      <div class="section-head">
        <h2 data-i18n="contact">Contact</h2>
        <p data-i18n="contactTag">
          You can reach me through email, GitHub, or LinkedIn.
        </p>
      </div>

      <div class="card contact-card">
        <p data-i18n="contactText">
          I'm open to internship opportunities, feedback, and conversations
          about software, programming, or hardware-related work while I keep
          growing as a developer.
        </p>

        <div class="hero-actions">
          <a class="cta-button secondary" href="mailto:walenculd@gmail.com"
            >walenculd@gmail.com</a
          >
          <a
            class="cta-button secondary"
            href="https://github.com/Walasbrrr"
            target="_blank"
            rel="noreferrer">GitHub</a
          >
          <a
            class="cta-button secondary"
            href="https://www.linkedin.com/in/walen-calderon-a017b42a4/"
            target="_blank"
            rel="noreferrer">LinkedIn</a
          >
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
