---
import BaseLayout from "../layouts/baseLayout.astro";
import LangInit      from "../components/LangInit";
import Navbar        from "../components/Navbar";
import Hero          from "../components/Hero";
import AboutSection      from "../components/AboutSection.astro";
import ProjectsSection   from "../components/ProjectsSection";
import SkillsSection     from "../components/SkillsSection";
import ExperienceSection from "../components/ExperienceSection.astro";
import EducationSection  from "../components/EducationSection.astro";
import ContactSection    from "../components/ContactSection";
---

<BaseLayout>
  <!-- Sincroniza localStorage → store, sin renderizar nada -->
  <LangInit client:load />

  <!-- Interactivos inmediatos: scroll spy, animación de tipeo -->
  <Navbar client:load />
  <Hero   client:load />

  <!-- Secciones: se hidratan cuando el browser está libre -->
  <AboutSection />
  <ProjectsSection   client:idle />
  <SkillsSection     client:idle />
  <ExperienceSection />
  <EducationSection />
  <ContactSection    client:idle />
</BaseLayout>
